# [Created by task 2.5.3 3/27/2021 15:34:47]
# Taskwarrior program configuration file.
# For more documentation, see http://taskwarrior.org or try 'man task', 'man task-color',
# 'man task-sync' or 'man taskrc'

dateformat=D-M-Y
dateformat.edit=D-M-Y H:N:S
dateformat.holiday=DMY
dateformat.info=D-M-Y H:N:S
# Here is an example of entries that use the default, override and blank values
#   variable=foo   -- By specifying a value, this overrides the default
#   variable=      -- By specifying no value, this means no default
#   #variable=foo  -- By commenting out the line, or deleting it, this uses the default

# Use the command 'task show' to see all defaults and overrides

# Files
data.location=~/.task

# TODO change this
include /nix/store/9l4qlfpgpi418zi7a1d2xgdc0l8dg0bf-taskwarrior-2.5.3/share/doc/task/rc/dark-16.theme

#Contextts
context.work=-personal +college +work
context.rest=-college -work
context.study=+study 
