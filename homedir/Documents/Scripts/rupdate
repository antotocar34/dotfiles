rclone_command () {
    truncatePath () {
    echo $1 | sed 's#.*\(Documents\)#\1#g'
        }

    exclude_file=/home/carneca/.config/nixpkgs/extraConfigs/.config/rclone/exclude_list.txt
    ${HOME}/.nix-profile/bin/rclone $2 -v ${1}/ tdrive:/backup/$(truncatePath $1)/ --filter-from  $exclude_file
    }

if [[ $1 = "-s" ]]; then
    input_full=$(readlink -f $2)
    rclone_command $input_full sync
else
    input_full=$(readlink -f $1)
    rclone_command $input_full copy
fi
