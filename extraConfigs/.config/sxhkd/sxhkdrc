alt + w
    ${HOME}/Documents/Scripts/find_tex.sh

alt + r  
    ${HOME}/Documents/Scripts/find_pdf.sh

alt + f
    kitty --name vifm -e vifm .

shift + alt + t 
    kitty --name tmux tmux a

alt + Return 
    rofi -show drun -show-icons

alt + v 
   kitty -e  nvim tmp

alt + n
   bitwarden 

alt + m
   tdrop -n=1 -ma -w -4 -y "$PANEL_HEIGHT" kitty --name cmus-term -e cmus

ctrl + Return
    kitty --name term0 -d ~ env TDROP= bash

F12
    tdrop --number=421 -ma -w -4 -y "50%" kitty --name term1 -d ~ env TDROP="red" bash

ctrl + b
    chromium --new-window https://www.google.com

shift + ctrl + g
    tdrop -w "100%" -h "100%" --number=google -ma chromium --new-window https://www.google.com

shift + ctrl + m
    tdrop -w "100%" -h "100%" --number=messenger -ma chromium --new-window https://www.messenger.com/t/100009009790305/

alt + shift + b
    tdrop -w "100%" -h "100%" --number=books -ma chromium --new-window https://z-lib.org/ 

alt + s
    anki

alt + e
    rofi -show window

Print
    flameshot gui

alt + shift + r
    pkill -usr1 -x sxhkd ; notify-send --expire-time=2000 'sxhkd' 'Reloaded config'

alt + shift + p
    bw generate -p --words 5 | xclip -selection clipboard ; notify-send --expire-time=2000 'Generated password'
